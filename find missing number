public class findmissingnumber {
    public static void main(String[] args) {
        int[] arr = {2,1,0,2};
        
        System.out.println(find(arr));

    }

    static int find(int[] arr){
        int i = 0;
        while(i<arr.length){
            int complete = arr[i];
            if(arr[i]<arr.length && arr[i]!=arr[complete]){
                swap(arr,i,complete);
                dublicate(arr);
            }else{
                i++;
            }
            
        }return dublicate(arr);
    }

    static void swap(int[] arr,int i , int complete){
        int temp = arr[complete];
        arr[complete] = arr[i];
        arr[i]= temp;

    }
    static int dublicate(int[]arr){
        for(int index = 0; index<arr.length;index++){
            if(arr[index]!=index){
                return index;

               
            }else{
                continue;
            }
        }return arr.length;

    }
        
    



}
