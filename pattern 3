public class pattern1{
    public static void main(String[] args) {
        int num = 5;
        for(int row =1;row<2*num-1;row++){
            if(row>num){
                for(int col=1;col<2*num-row;col++){
                    System.out.print("*");

                }
            }else{ 
                for(int col = 0;col<row;col++){
                    System.out.print("*");
                }
            }System.out.println();
        
        }
        

    }
} 
